{
  "name": "dynamic-island",
  "version": "1.0.0",
  "type": "module",
  "description": "Dynamic Island for your laptop — a living, breathing menu bar overlay",
  "main": "dist-electron/main.cjs",
  "homepage": "./",
  "author": "Dynamic Island",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\" --kill-others",
    "build": "vite build && electron-builder",
    "build:renderer": "vite build",
    "preview": "vite preview",
    "electron:dev": "electron ."
  },
  "build": {
    "appId": "com.dynamicisland.app",
    "productName": "Dynamic Island",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "howler": "^2.2.4",
    "lucide-react": "^0.453.0",
    "music-metadata": "^7.14.0",
    "node-powershell": "^5.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "node-gyp": "^12.2.0",
    "vite": "^6.4.1",
    "vite-plugin-electron": "^0.28.8",
    "wait-on": "^8.0.5"
  }
}
